doctype html
head
  // Required meta tags
  meta(charset='utf-8')
  meta(name='viewport' content='width=device-width, initial-scale=1')
  link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css")
  // Bootstrap CSS
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.0.1/dist/css/bootstrap.min.css' rel='stylesheet' integrity='sha384-+0n0xVW2eSR5OomGNYDnhzAbDsOXxcvSN1TPprVMTNDbiYZCxYbOOl7+AMvyTG2x' crossorigin='anonymous')
  link(rel="stylesheet", href="style.css")
  title Portfolio of E. Wright
body 
    include includes/header.pug
    main.flex-grow-1.d-flex.flex-column.py-3
        .container.h-100.d-flex.flex-column.align-items-center.justify-content-center.text-light 
            .row.align-items-center
                .col-12.col-lg-4 
                    h1 If you're looking for a hybrid UI designer + developer, you've come to the right place.
                    p.text-muted.mb-5.mt-4 Let's discuss how we can take your front-end UI or software development project to the next level.
                    .row 
                        .col-6 
                            a.btn.btn-primary.mr-3.w-100(href="./portfolio.html") View Work 
                        .col-6
                            a.btn.btn-outline-primary.w-100(href="./contact.html") Contact Me 
                .col-12.col-lg-8
                    .home-img-wrapper
                        img.img-fluid.home-img(src="images/me.png", alt="")
                        .design-wrapper 
                            h4 Design 
                            p Only need design? Cool. Here are a few tools I use on a daily.
                            .row 
                                .col-6
                                    ul.list-group.list-group-flush
                                        li.list-group-item Adobe XD 
                                        li.list-group-item Adobe Illustrator
                                        li.list-group-item Design System Management
                                        
                                        
                                .col-6
                                    ul.list-group
                                        li.list-group-item Adobe Photoshop
                                        li.list-group-item Design Thinking
                                        li.list-group-item Color Theory
                                        

                        .dev-wrapper 
                            h4 Development
                            p Need design and development. Say no more.
                            .row 
                                .col-6
                                    ul.list-group.list-group-flush
                                        li.list-group-item VScode
                                        li.list-group-item React
                                        li.list-group-item Pug.js
                                        
                                .col-6
                                    ul.list-group
                                        li.list-group-item Angular (learning)
                                        li.list-group-item HTML/CSS/JS
                                        li.list-group-item Agile/Sprints
    include includes/footer.pug
